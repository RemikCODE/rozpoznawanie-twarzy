@model List<FaceRecognitionApi.Models.RecognitionLog>
@using FaceRecognitionApi.Models

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>czas</th>
                    <th>status</th>
                    <th>osoba</th>
                    <th>pewnosc</th>
                    <th>wiadomosc</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="small" style="color:var(--bs-secondary-color)">@log.RecognizedAt.ToString("yyyy-MM-dd HH:mm:ss") utc</td>
                        <td>
                            @if (log.Found)
                            {
                                <span class="badge bg-success">znaleziono</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">nie znaleziono</span>
                            }
                        </td>
                        <td class="fw-semibold">@(string.IsNullOrEmpty(log.PersonName) ? "—" : log.PersonName)</td>
                        <td>@(log.Found ? $"{log.Confidence * 100:F1}%" : "—")</td>
                        <td class="small" style="color:var(--bs-secondary-color)">@log.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info">
        nie ma jeszcze wynikow rozpoznan wyslij zdjecie z aplikacji mobilnej lub desktopowej zeby zobaczyc wyniki tutaj
    </div>
}
