<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.MainPage"
             Title="rozpoznawanie twarzy"
             BackgroundColor="{DynamicResource PageBg}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{DynamicResource Surface}"
                             Padding="20,28,20,20"
                             Spacing="4">
            <Label Text="rozpoznawanie twarzy"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="0.3" />
            <Label x:Name="InstructionLabel"
                   FontSize="13"
                   TextColor="{DynamicResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
            <BoxView HeightRequest="1"
                     Color="{DynamicResource BorderColor}"
                     Margin="0,12,0,0" />
        </VerticalStackLayout>

        <!-- ── Scrollable content ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Photo preview card -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{DynamicResource Surface}"
                        HeightRequest="260">
                    <Grid>
                        <VerticalStackLayout x:Name="PhotoPlaceholder"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="10">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1.5"
                                    BackgroundColor="{DynamicResource SurfaceElev}"
                                    WidthRequest="72"
                                    HeightRequest="60"
                                    HorizontalOptions="Center" />
                            <Label Text="brak obrazu"
                                   TextColor="{DynamicResource TextMuted}"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <Image x:Name="PhotoPreview"
                               Aspect="AspectFit"
                               IsVisible="False" />
                    </Grid>
                </Border>

                <!-- Result card (shown after recognition) -->
                <Border x:Name="ResultCard"
                        IsVisible="False"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{DynamicResource Surface}"
                        Padding="20,16">
                    <VerticalStackLayout Spacing="14">

                        <Label x:Name="ResultStatusLabel"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               CharacterSpacing="0.2" />

                        <BoxView HeightRequest="1" Color="{DynamicResource BorderColor}" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="osoba"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextMuted}"
                                       CharacterSpacing="1.5" />
                                <Label x:Name="ResultNameLabel"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="pewnosc"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextMuted}"
                                       CharacterSpacing="1.5" />
                                <Label x:Name="ResultConfidenceLabel"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextPrimary}" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label x:Name="ResultMessageLabel"
                               FontSize="12"
                               TextColor="{DynamicResource TextSecondary}"
                               HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom action bar ── -->
        <VerticalStackLayout Grid.Row="2"
                             BackgroundColor="{DynamicResource Surface}"
                             Padding="16,14,16,22"
                             Spacing="10">

            <BoxView HeightRequest="1"
                     Color="{DynamicResource BorderColor}"
                     Margin="-16,-14,-16,0" />

            <VerticalStackLayout x:Name="LoadingPanel"
                                 IsVisible="False"
                                 HorizontalOptions="Center"
                                 Spacing="8">
                <ActivityIndicator IsRunning="True"
                                   Color="{DynamicResource Accent}"
                                   HorizontalOptions="Center" />
                <Label Text="analizowanie obrazu"
                       FontSize="13"
                       TextColor="{DynamicResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Photo source buttons - TERAZ 3 PRZYCISKI -->
            <VerticalStackLayout x:Name="PhotoButtonsRow" Spacing="8">

                <!-- Galeria (dostępna na wszystkich platformach) -->
                <Button x:Name="GalleryButton"
                        Text="wybierz z galerii"
                        Clicked="OnGalleryClicked"
                        BackgroundColor="{DynamicResource SurfaceElev}"
                        TextColor="{DynamicResource TextPrimary}"
                        BorderColor="{DynamicResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44" />

                <!-- Desktop: file picker -->
                <Button x:Name="SelectFileButton"
                        Text="wybierz plik"
                        Clicked="OnSelectFileClicked"
                        BackgroundColor="{DynamicResource SurfaceElev}"
                        TextColor="{DynamicResource TextPrimary}"
                        BorderColor="{DynamicResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />

                <!-- Mobile: camera -->
                <Button x:Name="TakePhotoButton"
                        Text="zrob zdjecie"
                        Clicked="OnTakePhotoClicked"
                        BackgroundColor="{DynamicResource SurfaceElev}"
                        TextColor="{DynamicResource TextPrimary}"
                        BorderColor="{DynamicResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
            </VerticalStackLayout>

            <Button x:Name="RecognizeButton"
                    Text="rozpoznaj twarz"
                    Clicked="OnRecognizeClicked"
                    IsEnabled="False"
                    BackgroundColor="{DynamicResource Accent}"
                    TextColor="{DynamicResource TextPrimary}"
                    CornerRadius="8"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="50" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>