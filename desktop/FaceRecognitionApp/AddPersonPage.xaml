<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaceRecognitionApp.AddPersonPage"
             Title="dodaj osobe"
             BackgroundColor="{DynamicResource PageBg}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <VerticalStackLayout Grid.Row="0"
                             BackgroundColor="{DynamicResource Surface}"
                             Padding="20,28,20,20"
                             Spacing="4">
            <Label Text="dodaj osobe"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{DynamicResource TextPrimary}"
                   HorizontalTextAlignment="Center"
                   CharacterSpacing="0.3" />
            <Label Text="zarejestruj nowa osobe w bazie"
                   FontSize="13"
                   TextColor="{DynamicResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
            <BoxView HeightRequest="1"
                     Color="{DynamicResource BorderColor}"
                     Margin="0,12,0,0" />
        </VerticalStackLayout>

        <!-- ── Scrollable content ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Name input card -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{DynamicResource Surface}"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="imie i nazwisko"
                               FontSize="10"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TextMuted}"
                               CharacterSpacing="1.5" />
                        <Entry x:Name="NameEntry"
                               Placeholder="np jan kowalski"
                               PlaceholderColor="{DynamicResource TextMuted}"
                               TextColor="{DynamicResource TextPrimary}"
                               BackgroundColor="Transparent"
                               FontSize="15"
                               TextChanged="OnNameTextChanged" />
                    </VerticalStackLayout>
                </Border>

                <!-- Photo preview card -->
                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{DynamicResource Surface}"
                        HeightRequest="220">
                    <Grid>
                        <!-- Placeholder -->
                        <VerticalStackLayout x:Name="PhotoPlaceholder"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="10">
                            <Border StrokeShape="RoundRectangle 8"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1.5"
                                    BackgroundColor="{DynamicResource SurfaceElev}"
                                    WidthRequest="72"
                                    HeightRequest="60"
                                    HorizontalOptions="Center" />
                            <Label Text="brak zdjecia"
                                   TextColor="{DynamicResource TextMuted}"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                        <!-- Selected photo -->
                        <Image x:Name="PhotoPreview"
                               Aspect="AspectFit"
                               IsVisible="False" />
                    </Grid>
                </Border>

                <!-- Result card (shown after successful add) -->
                <Border x:Name="ResultCard"
                        IsVisible="False"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        BackgroundColor="{DynamicResource Surface}"
                        Padding="20,16">
                    <VerticalStackLayout Spacing="6">
                        <Label x:Name="ResultStatusLabel"
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="ResultDetailLabel"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondary}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Bottom action bar ── -->
        <VerticalStackLayout Grid.Row="2"
                             BackgroundColor="{DynamicResource Surface}"
                             Padding="16,14,16,22"
                             Spacing="10">

            <BoxView HeightRequest="1"
                     Color="{DynamicResource BorderColor}"
                     Margin="-16,-14,-16,0" />

            <!-- Loading state -->
            <VerticalStackLayout x:Name="LoadingPanel"
                                 IsVisible="False"
                                 HorizontalOptions="Center"
                                 Spacing="8">
                <ActivityIndicator IsRunning="True"
                                   Color="{DynamicResource Accent}"
                                   HorizontalOptions="Center" />
                <Label Text="zapisywanie osoby"
                       FontSize="13"
                       TextColor="{DynamicResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Photo source buttons - TERAZ 3 PRZYCISKI -->
            <VerticalStackLayout x:Name="PhotoButtonsRow" Spacing="8">

                <!-- NOWY PRZYCISK GALERII -->
                <Button x:Name="GalleryButton"
                        Text="wybierz z galerii"
                        Clicked="OnGalleryClicked"
                        BackgroundColor="{DynamicResource SurfaceElev}"
                        TextColor="{DynamicResource TextPrimary}"
                        BorderColor="{DynamicResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44" />

                <Button x:Name="SelectFileButton"
                        Text="wybierz plik"
                        Clicked="OnSelectFileClicked"
                        BackgroundColor="{DynamicResource SurfaceElev}"
                        TextColor="{DynamicResource TextPrimary}"
                        BorderColor="{DynamicResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
                <Button x:Name="TakePhotoButton"
                        Text="zrob zdjecie"
                        Clicked="OnTakePhotoClicked"
                        BackgroundColor="{DynamicResource SurfaceElev}"
                        TextColor="{DynamicResource TextPrimary}"
                        BorderColor="{DynamicResource BorderColor}"
                        BorderWidth="1"
                        CornerRadius="8"
                        FontSize="14"
                        HeightRequest="44"
                        IsVisible="False" />
            </VerticalStackLayout>

            <!-- Primary action button -->
            <Button x:Name="AddButton"
                    Text="dodaj osobe"
                    Clicked="OnAddClicked"
                    IsEnabled="False"
                    BackgroundColor="{DynamicResource Accent}"
                    TextColor="{DynamicResource TextPrimary}"
                    CornerRadius="8"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="50" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>